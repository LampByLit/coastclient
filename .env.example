# Same variables as used for Geoapify + Apify on your quote stack.
GEOAPIFY_API_KEY=
APIFY_TOKEN=

# Formspree form id (from https://formspree.io) — set notification email to sales@coastteammoving.com in the Formspree dashboard.
VITE_FORMSPREE_FORM_ID=

# --- Formspree notification email (deliverability) ---
# If messages are missing or only in Spam/Junk: mark Formspree as "not spam" and add a filter to keep inbox.
# If they never arrive (server may have blocked Formspree): open once in a browser (logged in as the recipient if asked):
#   https://formspree.io/unblock/sales@coastteammoving.com
# Microsoft 365: also check Quarantine for messages from formspree.io (they may skip Inbox and Junk).
# Full guide: https://help.formspree.io/hc/en-us/articles/115008379388-I-m-not-receiving-emails
