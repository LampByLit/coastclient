# Same variables as used for Geoapify + Apify on your quote stack.
GEOAPIFY_API_KEY=
APIFY_TOKEN=

# Web3Forms access key (public; create at https://web3forms.com) — set notification email in the Web3Forms dashboard.
# Vite inlines this at build time: add the variable to your host’s *build* env (e.g. Railway) and redeploy, or the Book button stays disabled.
VITE_WEB3FORMS_ACCESS_KEY=
