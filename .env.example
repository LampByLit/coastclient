# Optional: public site quote APIs (geocode, routing, fuel) when not using the Vite dev proxy.
# Point to your Railway tool origin, including /api — e.g. https://your-app.up.railway.app/api
# Leave unset for local dev with proxy in vite.config.js → http://localhost:3001
# On Railway, set CORS_ORIGINS on the API service to this website's origin(s) so autocomplete and fuel work.
# VITE_QUOTE_API_BASE=https://your-app.up.railway.app/api
