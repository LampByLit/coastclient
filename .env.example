# =============================================================================
# NOT on Railway for the static marketing site — unless you build there.
# These are BUILD-TIME variables for Vite (import.meta.env). Set them wherever
# you run `npm run build` (GitHub Actions, Vercel, Netlify, Cloudflare Pages, etc.).
# =============================================================================

# Required in production: your Railway API service URL (origin only, no /api path).
# We append /api in code. Example:
#   VITE_QUOTE_API_BASE=https://your-api-service.up.railway.app
# Leave unset for local dev — Vite proxies /api → http://localhost:3001 (see vite.config.js).
VITE_QUOTE_API_BASE=

# =============================================================================
# Railway checklist (separate service — the "tool" / API repo)
# You must configure the API service on Railway or the quote page cannot geocode.
# Copy tool/.env.example → set variables in Railway → Variables for that service.
# =============================================================================
#   GEOAPIFY_API_KEY   — from Geoapify My Projects
#   APIFY_TOKEN        — for fuel proxy (optional if you only care about addresses)
#   CORS_ORIGINS       — must include your LIVE website origin, e.g. https://www.yoursite.com
# =============================================================================
